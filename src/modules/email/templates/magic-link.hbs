<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8" />
  <title>Sign in to BeOrchid</title>
</head>
<body style="font-family: sans-serif; max-width: 480px; margin: 0 auto; padding: 24px; color: #111;">
  <h2>Hello, {{firstName}}!</h2>
  <p>Click the link below to sign in to your BeOrchid account. This link expires in <strong>15 minutes</strong>.</p>
  <p style="margin: 32px 0;">
    <a href="{{link}}"
       style="background:#16a34a;color:#fff;padding:12px 24px;border-radius:6px;text-decoration:none;font-weight:600;">
      Sign in to BeOrchid
    </a>
  </p>
  <p style="color:#6b7280;font-size:13px;">If you didn't request this, you can safely ignore this email.</p>
</body>
</html>
